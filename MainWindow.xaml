<Window x:Class="MyHippocrates.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hippocrates — Аптечная сеть"
        Height="760" Width="1280"
        WindowState="Maximized"
        Background="#0D1F0F"
        Icon="/icon.ico">

    <Window.Resources>
        <!-- Нумерация строк в DataGrid -->
        <Style x:Key="RowNumStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Foreground"          Value="#81C784"/>
            <Setter Property="FontSize"            Value="12"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="Background"               Value="#132B15"/>
            <Setter Property="RowBackground"            Value="#132B15"/>
            <Setter Property="AlternatingRowBackground" Value="#0D1F0F"/>
            <Setter Property="Foreground"               Value="#E8F5E9"/>
            <Setter Property="BorderBrush"              Value="#2E7D32"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1B5E20"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#1B5E20"/>
            <Setter Property="Foreground"      Value="#C8E6C9"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="10 8"/>
            <Setter Property="BorderBrush"     Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E7D32"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A3D1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="8 5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground"  Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопка ДОБАВИТЬ (зелёная) -->
        <Style x:Key="BtnAdd" TargetType="Button">
            <Setter Property="Background"      Value="#2E7D32"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14 7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#43A047"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка РЕДАКТИРОВАТЬ (синяя) -->
        <Style x:Key="BtnEdit" TargetType="Button" BasedOn="{StaticResource BtnAdd}">
            <Setter Property="Background" Value="#1565C0"/>
            <Style.Resources/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#444"/>
                    <Setter Property="Foreground"  Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопка УДАЛИТЬ (красная) -->
        <Style x:Key="BtnDelete" TargetType="Button" BasedOn="{StaticResource BtnAdd}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E53935"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#444"/>
                    <Setter Property="Foreground"  Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox поиска -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#132B15"/>
            <Setter Property="Foreground"      Value="#E8F5E9"/>
            <Setter Property="BorderBrush"     Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8 6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Width"           Value="240"/>
            <Setter Property="CaretBrush"      Value="#E8F5E9"/>
        </Style>

        <!-- TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#132B15"/>
            <Setter Property="Foreground" Value="#81C784"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="16 9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" Margin="0 0 2 0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E7D32"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3D1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Шапка -->
        <Border DockPanel.Dock="Top" Background="white" Padding="20 14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel>
                        <Image Source="/logo.jpg" Width="308" Height="68"/>

                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Background="#0D1F0F" BorderThickness="0" SelectionChanged="TabControl_SelectionChanged">

            <!-- ══ ПРОИЗВОДИТЕЛИ ═══════════════════════════════════════ -->
            <TabItem Header="Производители">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" HorizontalAlignment="Left"
                                 Text="{Binding ManufacturersVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Добавить"   Style="{StaticResource BtnAdd}"
                                    Command="{Binding ManufacturersVM.AddCommand}"/>
                            <Button Content="Изменить"  Style="{StaticResource BtnEdit}" Margin="6 0"
                                    Command="{Binding ManufacturersVM.EditCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ManufacturersGrid}"/>
                            <Button Content="Удалить"   Style="{StaticResource BtnDelete}"
                                    Command="{Binding ManufacturersVM.DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ManufacturersGrid}"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="ManufacturersGrid"
                              ItemsSource="{Binding ManufacturersVM.View}"
                              LoadingRow="DataGrid_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                          Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Название"  Binding="{Binding Name}"    Width="160"/>
                            <DataGridTextColumn Header="Страна"    Binding="{Binding Country}" Width="110"/>
                            <DataGridTextColumn Header="Адрес"     Binding="{Binding Address}" Width="*"/>
                            <DataGridTextColumn Header="Телефон"   Binding="{Binding Phone}"   Width="140"/>
                            <DataGridTextColumn Header="Email"     Binding="{Binding Email}"   Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ ТОВАРЫ ═══════════════════════════════════════════════ -->
            <TabItem Header="Товары">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" HorizontalAlignment="Left"
                                 Text="{Binding ProductsVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Добавить"  Style="{StaticResource BtnAdd}"    Command="{Binding ProductsVM.AddCommand}"/>
                            <Button Content="Изменить" Style="{StaticResource BtnEdit}"   Margin="6 0" Command="{Binding ProductsVM.EditCommand}"   CommandParameter="{Binding SelectedItem, ElementName=ProductsGrid}"/>
                            <Button Content="Удалить"  Style="{StaticResource BtnDelete}" Command="{Binding ProductsVM.DeleteCommand}" CommandParameter="{Binding SelectedItem, ElementName=ProductsGrid}"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="ProductsGrid"
                              ItemsSource="{Binding ProductsVM.View}"
                              LoadingRow="DataGrid_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}" Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Название"       Binding="{Binding Name}"                                          Width="160"/>
                            <DataGridTextColumn Header="Производитель"  Binding="{Binding Manufacturer.Name}"                             Width="140"/>
                            <DataGridTextColumn Header="Дата пр-ва"     Binding="{Binding ProductionDate, StringFormat={}{0:dd.MM.yyyy}}"  Width="100"/>
                            <DataGridTextColumn Header="Срок годн."     Binding="{Binding ExpirationDate, StringFormat={}{0:dd.MM.yyyy}}"  Width="100"/>
                            <DataGridTextColumn Header="Ед."            Binding="{Binding Unit}"                                          Width="50"/>
                            <DataGridTextColumn Header="Рецепт"         Binding="{Binding PrescriptionRequired}"                          Width="65"/>
                            <DataGridTextColumn Header="Закупка"        Binding="{Binding PurchasePrice, StringFormat={}{0:F2}}"           Width="85"/>
                            <DataGridTextColumn Header="Продажа"        Binding="{Binding SalePrice,     StringFormat={}{0:F2}}"           Width="85"/>
                            <DataGridTextColumn Header="Описание"       Binding="{Binding Description}"                                   Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ АПТЕКИ ════════════════════════════════════════════════ -->
            <TabItem Header="Аптеки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" HorizontalAlignment="Left"
                                 Text="{Binding PharmaciesVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Добавить"  Style="{StaticResource BtnAdd}"    Command="{Binding PharmaciesVM.AddCommand}"/>
                            <Button Content="Изменить" Style="{StaticResource BtnEdit}"   Margin="6 0" Command="{Binding PharmaciesVM.EditCommand}"   CommandParameter="{Binding SelectedItem, ElementName=PharmaciesGrid}"/>
                            <Button Content="Удалить"  Style="{StaticResource BtnDelete}" Command="{Binding PharmaciesVM.DeleteCommand}" CommandParameter="{Binding SelectedItem, ElementName=PharmaciesGrid}"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="PharmaciesGrid"
                              ItemsSource="{Binding PharmaciesVM.View}"
                              LoadingRow="DataGrid_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}" Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Адрес"       Binding="{Binding Address}"      Width="*"/>
                            <DataGridTextColumn Header="Телефон"     Binding="{Binding Phone}"        Width="150"/>
                            <DataGridTextColumn Header="Часы работы" Binding="{Binding WorkingHours}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ СОТРУДНИКИ ════════════════════════════════════════════ -->
            <TabItem Header="Сотрудники">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" HorizontalAlignment="Left"
                                 Text="{Binding EmployeesVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Добавить"  Style="{StaticResource BtnAdd}"    Command="{Binding EmployeesVM.AddCommand}"/>
                            <Button Content="Изменить" Style="{StaticResource BtnEdit}"   Margin="6 0" Command="{Binding EmployeesVM.EditCommand}"   CommandParameter="{Binding SelectedItem, ElementName=EmployeesGrid}"/>
                            <Button Content="Удалить"  Style="{StaticResource BtnDelete}" Command="{Binding EmployeesVM.DeleteCommand}" CommandParameter="{Binding SelectedItem, ElementName=EmployeesGrid}"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="EmployeesGrid"
                              ItemsSource="{Binding EmployeesVM.View}"
                              LoadingRow="DataGrid_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}" Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ФИО"       Binding="{Binding FullName}"  Width="*"/>
                            <DataGridTextColumn Header="IDNP"      Binding="{Binding Idnp}"      Width="130"/>
                            <DataGridTextColumn Header="Телефон"   Binding="{Binding Phone}"     Width="130"/>
                            <DataGridTextColumn Header="Адрес"     Binding="{Binding Address}"   Width="200"/>
                            <DataGridTextColumn Header="Зарплата"  Binding="{Binding Salary, StringFormat={}{0:F2}}" Width="100"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding Position}"  Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ ЧЕКИ ══════════════════════════════════════════════════ -->
            <TabItem Header="Чеки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" HorizontalAlignment="Left"
                                 Text="{Binding ReceiptsVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Добавить"  Style="{StaticResource BtnAdd}"    Command="{Binding ReceiptsVM.AddCommand}"/>
                            <Button Content="Удалить"  Style="{StaticResource BtnDelete}" Command="{Binding ReceiptsVM.DeleteCommand}" CommandParameter="{Binding SelectedItem, ElementName=ReceiptsGrid}"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="ReceiptsGrid"
                              ItemsSource="{Binding ReceiptsVM.View}"
                              LoadingRow="DataGrid_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}" Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="№ чека"    Binding="{Binding ReceiptNumber}"                             Width="80"/>
                            <DataGridTextColumn Header="Аптека"    Binding="{Binding Pharmacy.Address}"                          Width="*"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}"                         Width="180"/>
                            <DataGridTextColumn Header="Сумма"     Binding="{Binding TotalAmount, StringFormat={}{0:F2}}"        Width="90"/>
                            <DataGridTextColumn Header="Дата"      Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"       Width="100"/>
                            <DataGridTextColumn Header="Время"     Binding="{Binding Time, StringFormat={}{0:hh\\:mm\\:ss}}"    Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ ПОЗИЦИИ ЗАКАЗОВ ══════════════════════════════════════ -->
            <TabItem Header="Позиции заказов">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" HorizontalAlignment="Left"
                                 Text="{Binding OrderItemsVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Добавить"  Style="{StaticResource BtnAdd}"    Command="{Binding OrderItemsVM.AddCommand}"/>
                            <Button Content="Изменить" Style="{StaticResource BtnEdit}"   Margin="6 0" Command="{Binding OrderItemsVM.EditCommand}"   CommandParameter="{Binding SelectedItem, ElementName=OrderItemsGrid}"/>
                            <Button Content="Удалить"  Style="{StaticResource BtnDelete}" Command="{Binding OrderItemsVM.DeleteCommand}" CommandParameter="{Binding SelectedItem, ElementName=OrderItemsGrid}"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="OrderItemsGrid"
                              ItemsSource="{Binding OrderItemsVM.View}"
                              LoadingRow="DataGrid_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}" Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Чек №"      Binding="{Binding Receipt.ReceiptNumber}"                         Width="80"/>
                            <DataGridTextColumn Header="Дата чека"  Binding="{Binding Receipt.Date, StringFormat={}{0:dd.MM.yyyy}}"   Width="100"/>
                            <DataGridTextColumn Header="Товар"      Binding="{Binding Product.Name}"                                  Width="*"/>
                            <DataGridTextColumn Header="Кол-во"     Binding="{Binding Quantity}"                                      Width="80"/>
                            <DataGridTextColumn Header="Цена ед."   Binding="{Binding UnitPrice, StringFormat={}{0:F2}}"              Width="90"/>
                            <DataGridTextColumn Header="Итого"      Binding="{Binding TotalPrice, StringFormat={}{0:F2}}"             Width="90"/>
                            <DataGridTextColumn Header="Скидка"     Binding="{Binding Discount, StringFormat={}{0:0.##}%}"            Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ ОСТАТКИ ══════════════════════════════════════════════ -->
            <TabItem Header="Остатки на складе">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75*"/>
                        <ColumnDefinition Width="1181*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 8" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" HorizontalAlignment="Left"
                                 Text="{Binding StockBalanceVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Добавить"  Style="{StaticResource BtnAdd}"    Command="{Binding StockBalanceVM.AddCommand}"/>
                            <Button Content="Изменить" Style="{StaticResource BtnEdit}"   Margin="6 0" Command="{Binding StockBalanceVM.EditCommand}"   CommandParameter="{Binding SelectedItem, ElementName=StockGrid}"/>
                            <Button Content="Удалить"  Style="{StaticResource BtnDelete}" Command="{Binding StockBalanceVM.DeleteCommand}" CommandParameter="{Binding SelectedItem, ElementName=StockGrid}"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid x:Name="StockGrid"
                              ItemsSource="{Binding StockBalanceVM.View}"
                              LoadingRow="DataGrid_LoadingRow" Grid.ColumnSpan="2" Margin="0,39,0,0" Grid.RowSpan="2">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}" Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Аптека"  Binding="{Binding Pharmacy.Address}" Width="*"/>
                            <DataGridTextColumn Header="Товар"   Binding="{Binding Product.Name}"     Width="*"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding RemainingQty}"     Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>