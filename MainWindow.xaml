<Window x:Class="MyHippocrates.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hippocrates — Аптечная сеть"
        Height="760" Width="1280"
        WindowState="Maximized"
        Background="#FFFFFF"
        Icon="/icon.ico">

    <Window.Resources>

        <!-- ══ Цвета ══════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="AccentGreen"    Color="#035b4b"/>
        <SolidColorBrush x:Key="AccentGreenHov" Color="#024a3d"/>
        <SolidColorBrush x:Key="TableHeaderBg"  Color="#035b4b"/>
        <SolidColorBrush x:Key="BgPage"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgRow"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgRowAlt"       Color="#f4fbf9"/>
        <SolidColorBrush x:Key="BorderLight"    Color="#cce3de"/>
        <SolidColorBrush x:Key="TextDark"       Color="#012920"/>
        <SolidColorBrush x:Key="TextMid"        Color="#2d6b5a"/>
        <SolidColorBrush x:Key="TextLight"      Color="#5a9b88"/>

        <!-- ══ Нумерация строк ════════════════════════════════════ -->
        <Style x:Key="RowNumStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Foreground"          Value="#5a9b88"/>
            <Setter Property="FontSize"            Value="12"/>
        </Style>

        <!-- ══ DataGrid ══════════════════════════════════════════ -->
        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="Background"               Value="#FFFFFF"/>
            <Setter Property="RowBackground"            Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#f4fbf9"/>
            <Setter Property="Foreground"               Value="#012920"/>
            <Setter Property="BorderBrush"              Value="#cce3de"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="GridLinesVisibility"      Value="None"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#e0f0ec"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
            <Setter Property="RowHeight"                Value="46"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#035b4b"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="14 10"/>
            <Setter Property="BorderBrush"     Value="#024a3d"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="BorderBrush"     Value="#e0f0ec"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#d0ede7"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e8f5f1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="14 0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#012920"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ Кнопка Добавить (зелёная заливка) ════════════════ -->
        <Style x:Key="BtnAdd" TargetType="Button">
            <Setter Property="Background"      Value="#035b4b"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20 9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#024a3d"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9dccc0"/>
                                <Setter Property="Foreground" Value="#5a9b88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Кнопка Изменить (контурная зелёная) ═════════════ -->
        <Style x:Key="BtnEdit" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#035b4b"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderBrush"     Value="#035b4b"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding"         Value="20 9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e5f4ef"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="BorderBrush" Value="#9dccc0"/>
                                <Setter Property="Foreground"  Value="#B0C8B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Кнопка Удалить (контурная красная) ══════════════ -->
        <Style x:Key="BtnDelete" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#C0392B"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderBrush"     Value="#C0392B"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding"         Value="20 9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FDF2F2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="BorderBrush" Value="#E8C5C2"/>
                                <Setter Property="Foreground"  Value="#E8C5C2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Поле поиска ══════════════════════════════════════ -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#edf8f5"/>
            <Setter Property="Foreground"      Value="#012920"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="34 9 12 9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Width"           Value="280"/>
            <Setter Property="CaretBrush"      Value="#035b4b"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <!-- Иконка лупы -->
                                <TextBlock Text="🔍" FontSize="12"
                                           Foreground="#5a9b88"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="10 0 0 0"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#035b4b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ TabItem — вкладки в стиле скриншота ══════════════ -->
        <Style TargetType="TabItem">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="#2d6b5a"/>
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="FontWeight"     Value="Normal"/>
            <Setter Property="Padding"        Value="20 12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#035b4b"
                                BorderThickness="0 0 0 0"
                                Margin="0 0 4 0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderThickness" Value="0 0 0 3"/>
                                <Setter Property="Foreground"  Value="#035b4b"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e5f4ef"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Кнопка шапки (Отчёты) — контурная ═══════════════ -->
        <Style x:Key="BtnHeader" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#012920"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontWeight"      Value="Normal"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20 10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#edf8f5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel Background="#FFFFFF">

        <!-- ══ ШАПКА ════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#cce3de"
                BorderThickness="0 0 0 1"
                Padding="28 14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <Image Source="/logo.jpg"
                       Height="60"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"/>

                <!-- Кнопки справа -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnHeader}"
                            Margin="0 0 10 0"
                            Click="OpenReports_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="14" Margin="0 0 6 0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Отчёты" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BtnAdd}"
                            Click="OpenDashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="15" Margin="0 0 6 0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ ВКЛАДКИ + КОНТЕНТ ════════════════════════════════ -->
        <TabControl Background="#FFFFFF"
                    BorderThickness="0"
                    SelectionChanged="TabControl_SelectionChanged"
                    Padding="0">

            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <DockPanel Background="White">
                        <!-- Полоса вкладок -->
                        <Border DockPanel.Dock="Top"
                                Background="#FFFFFF"
                                BorderBrush="#cce3de"
                                BorderThickness="0 0 0 1"
                                Padding="20 0 0 0">
                            <TabPanel IsItemsHost="True"/>
                        </Border>
                        <!-- Контент -->
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </DockPanel>
                </ControlTemplate>
            </TabControl.Template>

            <!-- ══ ПРОИЗВОДИТЕЛИ ═════════════════════════════════ -->
            <TabItem Header="Производители">
                <Grid Margin="24 16 24 16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Тулбар -->
                    <Grid Grid.Row="0" Margin="0 0 0 14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource SearchBox}"
                                 HorizontalAlignment="Left"
                                 Text="{Binding ManufacturersVM.SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Resources>
                                <Style TargetType="TextBox" BasedOn="{StaticResource SearchBox}"/>
                            </TextBox.Resources>
                        </TextBox>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BtnAdd}"
                                    Command="{Binding ManufacturersVM.AddCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnEdit}"
                                    Margin="8 0"
                                    Command="{Binding ManufacturersVM.EditCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ManufacturersGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✎" FontSize="14" Margin="0 0 6 0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Изменить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnDelete}"
                                    Command="{Binding ManufacturersVM.DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ManufacturersGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="1" x:Name="ManufacturersGrid"
                              ItemsSource="{Binding ManufacturersVM.View}"
                              LoadingRow="DataGrid_LoadingRow"
                              UnloadingRow="DataGrid_UnloadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Название"  Binding="{Binding Name}"    Width="180"/>
                            <DataGridTextColumn Header="Страна"    Binding="{Binding Country}" Width="120"/>
                            <DataGridTextColumn Header="Адрес"     Binding="{Binding Address}" Width="*"/>
                            <DataGridTextColumn Header="Телефон"   Binding="{Binding Phone}"   Width="150"/>
                            <DataGridTextColumn Header="Email"     Binding="{Binding Email}"   Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ ТОВАРЫ ════════════════════════════════════════ -->
            <TabItem Header="Товары">
                <Grid Margin="24 16 24 16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                                 HorizontalAlignment="Left"
                                 Text="{Binding ProductsVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BtnAdd}" Command="{Binding ProductsVM.AddCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnEdit}" Margin="8 0"
                                    Command="{Binding ProductsVM.EditCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ProductsGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✎" FontSize="14" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Изменить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnDelete}"
                                    Command="{Binding ProductsVM.DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ProductsGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="ProductsGrid"
                              ItemsSource="{Binding ProductsVM.View}"
                              LoadingRow="DataGrid_LoadingRow"
                              UnloadingRow="DataGrid_UnloadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Название"      Binding="{Binding Name}"                                         Width="180"/>
                            <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer.Name}"                            Width="150"/>
                            <DataGridTextColumn Header="Дата пр-ва"    Binding="{Binding ProductionDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                            <DataGridTextColumn Header="Срок годн."    Binding="{Binding ExpirationDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                            <DataGridTextColumn Header="Ед."           Binding="{Binding Unit}"                                         Width="54"/>
                            <DataGridTextColumn Header="Рецепт"        Binding="{Binding PrescriptionRequired}"                         Width="70"/>
                            <DataGridTextColumn Header="Закупка"       Binding="{Binding PurchasePrice, StringFormat={}{0:F2}}"          Width="90"/>
                            <DataGridTextColumn Header="Продажа"       Binding="{Binding SalePrice, StringFormat={}{0:F2}}"              Width="90"/>
                            <DataGridTextColumn Header="Описание"      Binding="{Binding Description}"                                  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ АПТЕКИ ════════════════════════════════════════ -->
            <TabItem Header="Аптеки">
                <Grid Margin="24 16 24 16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                                 HorizontalAlignment="Left"
                                 Text="{Binding PharmaciesVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BtnAdd}" Command="{Binding PharmaciesVM.AddCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnEdit}" Margin="8 0"
                                    Command="{Binding PharmaciesVM.EditCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=PharmaciesGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✎" FontSize="14" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Изменить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnDelete}"
                                    Command="{Binding PharmaciesVM.DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=PharmaciesGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="PharmaciesGrid"
                              ItemsSource="{Binding PharmaciesVM.View}"
                              LoadingRow="DataGrid_LoadingRow"
                              UnloadingRow="DataGrid_UnloadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Адрес"       Binding="{Binding Address}"      Width="*"/>
                            <DataGridTextColumn Header="Телефон"     Binding="{Binding Phone}"        Width="170"/>
                            <DataGridTextColumn Header="Часы работы" Binding="{Binding WorkingHours}" Width="170"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ СОТРУДНИКИ ════════════════════════════════════ -->
            <TabItem Header="Сотрудники">
                <Grid Margin="24 16 24 16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                                 HorizontalAlignment="Left"
                                 Text="{Binding EmployeesVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BtnAdd}" Command="{Binding EmployeesVM.AddCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnEdit}" Margin="8 0"
                                    Command="{Binding EmployeesVM.EditCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=EmployeesGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✎" FontSize="14" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Изменить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnDelete}"
                                    Command="{Binding EmployeesVM.DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=EmployeesGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="EmployeesGrid"
                              ItemsSource="{Binding EmployeesVM.View}"
                              LoadingRow="DataGrid_LoadingRow"
                              UnloadingRow="DataGrid_UnloadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ФИО"       Binding="{Binding FullName}"                           Width="*"/>
                            <DataGridTextColumn Header="IDNP"      Binding="{Binding Idnp}"                               Width="140"/>
                            <DataGridTextColumn Header="Телефон"   Binding="{Binding Phone}"                              Width="140"/>
                            <DataGridTextColumn Header="Адрес"     Binding="{Binding Address}"                            Width="220"/>
                            <DataGridTextColumn Header="Зарплата"  Binding="{Binding Salary, StringFormat={}{0:F2}}"      Width="110"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding Position}"                           Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ ЧЕКИ ══════════════════════════════════════════ -->
            <TabItem Header="Чеки">
                <Grid Margin="24 16 24 16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                                 HorizontalAlignment="Left"
                                 Text="{Binding ReceiptsVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BtnAdd}" Command="{Binding ReceiptsVM.AddCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnDelete}" Margin="8 0 0 0"
                                    Command="{Binding ReceiptsVM.DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ReceiptsGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="ReceiptsGrid"
                              ItemsSource="{Binding ReceiptsVM.View}"
                              LoadingRow="DataGrid_LoadingRow"
                              UnloadingRow="DataGrid_UnloadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="№ чека"    Binding="{Binding ReceiptNumber}"                           Width="90"/>
                            <DataGridTextColumn Header="Аптека"    Binding="{Binding Pharmacy.Address}"                        Width="*"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}"                       Width="190"/>
                            <DataGridTextColumn Header="Сумма"     Binding="{Binding TotalAmount, StringFormat={}{0:F2}}"      Width="100"/>
                            <DataGridTextColumn Header="Дата"      Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"     Width="110"/>
                            <DataGridTextColumn Header="Время"     Binding="{Binding Time, StringFormat={}{0:hh\\:mm\\:ss}}"  Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ ПОЗИЦИИ ЗАКАЗОВ ══════════════════════════════ -->
            <TabItem Header="Позиции заказов">
                <Grid Margin="24 16 24 16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                                 HorizontalAlignment="Left"
                                 Text="{Binding OrderItemsVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource BtnAdd}" Command="{Binding OrderItemsVM.AddCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnEdit}" Margin="8 0"
                                    Command="{Binding OrderItemsVM.EditCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=OrderItemsGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✎" FontSize="14" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Изменить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnDelete}"
                                    Command="{Binding OrderItemsVM.DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=OrderItemsGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="OrderItemsGrid"
                              ItemsSource="{Binding OrderItemsVM.View}"
                              LoadingRow="DataGrid_LoadingRow"
                              UnloadingRow="DataGrid_UnloadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                                   Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Чек №"     Binding="{Binding Receipt.ReceiptNumber}"                       Width="90"/>
                            <DataGridTextColumn Header="Дата чека" Binding="{Binding Receipt.Date, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                            <DataGridTextColumn Header="Товар"     Binding="{Binding Product.Name}"                                Width="*"/>
                            <DataGridTextColumn Header="Кол-во"    Binding="{Binding Quantity}"                                    Width="90"/>
                            <DataGridTextColumn Header="Цена ед."  Binding="{Binding UnitPrice, StringFormat={}{0:F2}}"            Width="100"/>
                            <DataGridTextColumn Header="Итого"     Binding="{Binding TotalPrice, StringFormat={}{0:F2}}"           Width="100"/>
                            <DataGridTextColumn Header="Скидка"    Binding="{Binding Discount, StringFormat={}{0:0.##}%}"          Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Остатки на складе">
                <Grid Margin="24 16 24 16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0 0 0 14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                     HorizontalAlignment="Left"
                     Text="{Binding StockBalanceVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <!-- Add button bound to StockBalanceVM.AddCommand -->
                            <Button Style="{StaticResource BtnAdd}" Command="{Binding StockBalanceVM.AddCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Edit button bound to StockBalanceVM.EditCommand with selected item parameter -->
                            <Button Style="{StaticResource BtnEdit}" Margin="8 0"
                        Command="{Binding StockBalanceVM.EditCommand}"
                        CommandParameter="{Binding SelectedItem, ElementName=StockGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✎" FontSize="14" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Изменить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Delete button bound to StockBalanceVM.DeleteCommand with selected item parameter -->
                            <Button Style="{StaticResource BtnDelete}"
                        Command="{Binding StockBalanceVM.DeleteCommand}"
                        CommandParameter="{Binding SelectedItem, ElementName=StockGrid}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="StockGrid"
                  ItemsSource="{Binding StockBalanceVM.View}"
                  LoadingRow="DataGrid_LoadingRow"
                  UnloadingRow="DataGrid_UnloadingRow">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="№" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource RowNumStyle}"
                                       Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Аптека"  Binding="{Binding Pharmacy.Address}" Width="*"/>
                            <DataGridTextColumn Header="Товар"   Binding="{Binding Product.Name}"     Width="*"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding RemainingQty}"     Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
