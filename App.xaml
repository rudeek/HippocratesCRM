<Application x:Class="MyHippocrates.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:MyHippocrates.Models"
             xmlns:vm="clr-namespace:MyHippocrates.ViewModels"
             StartupUri="Views/ConnectionWindow.xaml">
    <Application.Resources>

        <!-- MANUFACTURER -->
        <DataTemplate DataType="{x:Type models:Manufacturer}">
            <StackPanel Width="440">
                <Label Content="Название *"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Страна *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="OnlyLetters_PreviewTextInput"/>
                <Label Content="Адрес *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Телефон * (начинается с +)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="PhoneNumber_PreviewTextInput"/>
                <Label Content="Email * (содержит @)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>

        <!-- PHARMACY -->
        <DataTemplate DataType="{x:Type models:Pharmacy}">
            <StackPanel Width="440">
                <Label Content="Адрес *"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Телефон * (начинается с +)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="PhoneNumber_PreviewTextInput"/>
                <Label Content="Часы работы *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding WorkingHours, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>

        <!-- EMPLOYEE -->
        <DataTemplate DataType="{x:Type vm:EmployeeEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="ФИО *"/>
                <TextBox Text="{Binding Entity.FullName, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="OnlyLetters_PreviewTextInput"/>
                <Label Content="IDNP * (13 цифр)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Idnp, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="13"
                         PreviewTextInput="OnlyDigits_PreviewTextInput"/>
                <Label Content="Телефон * (начинается с +)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Phone, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="PhoneNumber_PreviewTextInput"/>
                <Label Content="Адрес" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Address, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Должность * (зарплата указана в роли)" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Roles}"
                          SelectedValue="{Binding Entity.RoleId, Mode=TwoWay}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Name">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Padding="2 4">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} — {1:F0} MDL">
                                        <Binding Path="Name"/>
                                        <Binding Path="FixedSalary"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </DataTemplate>

        <!-- PRODUCT -->
        <DataTemplate DataType="{x:Type vm:ProductEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Название *"/>
                <TextBox Text="{Binding Entity.Name, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Производитель *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Manufacturers}"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding Entity.ManufacturerId, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="Категория *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding Entity.CategoryId, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="Дата производства *" Margin="0,12,0,0"/>
                <DatePicker SelectedDate="{Binding Entity.ProductionDate, Mode=TwoWay}"/>
                <Label Content="Срок годности * (позже даты производства)" Margin="0,12,0,0"/>
                <DatePicker SelectedDate="{Binding Entity.ExpirationDate, Mode=TwoWay}"/>
                <Label Content="Единица измерения *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Unit, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Описание" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>

                <!-- FilePath с кнопкой проводника -->
                <Label Content="Путь к картинке" Margin="0,12,0,0"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,6,0"/>
                    <Button Grid.Column="1"
                            Content="📁"
                            Width="38"
                            Height="38"
                            VerticalAlignment="Top"
                            Tag="{Binding}"
                            Click="BrowseImage_Click"
                            ToolTip="Выбрать файл"/>
                </Grid>

                <Label Content="Закупочная цена * (> 0)" Margin="0,12,0,0"/>
                <TextBox PreviewTextInput="Price_PreviewTextInput">
                    <TextBox.Text>
                        <Binding Path="Entity.PurchasePrice"
                                 UpdateSourceTrigger="LostFocus"
                                 StringFormat="{}{0:0.##}"/>
                    </TextBox.Text>
                </TextBox>
                <Label Content="Розничная цена * (≥ закупочной)" Margin="0,12,0,0"/>
                <TextBox PreviewTextInput="Price_PreviewTextInput">
                    <TextBox.Text>
                        <Binding Path="Entity.SalePrice"
                                 UpdateSourceTrigger="LostFocus"
                                 StringFormat="{}{0:0.##}"/>
                    </TextBox.Text>
                </TextBox>
                <CheckBox Content="Требует рецепта"
                          IsChecked="{Binding Entity.PrescriptionRequired, Mode=TwoWay}"
                          Margin="0,14,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- RECEIPT -->
        <DataTemplate DataType="{x:Type vm:ReceiptEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Аптека *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Pharmacies}"
                  DisplayMemberPath="Address"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding Entity.PharmacyId, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Address}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="Сотрудник *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Employees}"
                  DisplayMemberPath="FullName"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding Entity.EmployeeId, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </DataTemplate>

        <!-- ORDER ITEM -->
        <DataTemplate DataType="{x:Type vm:OrderItemEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Аптека (фильтр чеков) *"/>
                <ComboBox ItemsSource="{Binding Pharmacies}"
                  SelectedItem="{Binding SelectedPharmacy, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Address}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Label Content="Чек * (только сегодняшние)" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding FilteredReceipts}"
                  SelectedItem="{Binding SelectedReceipt, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Padding="2 4">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="№{0} — {1:dd.MM.yyyy}">
                                        <Binding Path="ReceiptNumber"/>
                                        <Binding Path="Date"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Label Content="Товар * (только из склада выбранной аптеки)" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding AvailableProducts}"
                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Label Content="Количество * (> 0)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Quantity, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="OnlyDigits_PreviewTextInput"/>
                <Label Content="Скидка % (0–100)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Discount, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="Price_PreviewTextInput"/>
            </StackPanel>
        </DataTemplate>

        <!-- STOCK BALANCE -->
        <DataTemplate DataType="{x:Type vm:StockBalanceEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Аптека *"/>
                <ComboBox ItemsSource="{Binding Pharmacies}"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding Entity.PharmacyId, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Address}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="Товар *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Products}"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding Entity.ProductId, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="Остаток (≥ 0)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.RemainingQty, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>

        <!-- CATEGORY -->
        <DataTemplate DataType="{x:Type models:Category}">
            <StackPanel Width="440">
                <Label Content="Название *"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Описание" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>

        <!-- ROLE -->
        <DataTemplate DataType="{x:Type models:Role}">
            <StackPanel Width="440">
                <Label Content="Название *"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Фиксированная зарплата * (> 0)" Margin="0,12,0,0"/>
                <TextBox PreviewTextInput="Price_PreviewTextInput">
                    <TextBox.Text>
                        <Binding Path="FixedSalary"
                                 UpdateSourceTrigger="LostFocus"
                                 StringFormat="{}{0:0.##}"/>
                    </TextBox.Text>
                </TextBox>
                <Label Content="Описание" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>

        <!-- SYSTEM USER -->
        <DataTemplate DataType="{x:Type vm:SystemUserEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Сотрудник *"/>
                <ComboBox ItemsSource="{Binding AvailableEmployees}"
                          SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}" Padding="2 4"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Content="Логин *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Login, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Пароль * (при редактировании оставьте пустым, чтобы не менять)"
                       Margin="0,12,0,0"/>
                <TextBox Text="{Binding PlainPassword, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Системная роль (устанавливается автоматически триггером БД)"
                       Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.SystemRole}" IsReadOnly="True"
                         Background="#f0f0f0" Foreground="#888"/>
                <CheckBox Content="Активен"
                          IsChecked="{Binding Entity.IsActive, Mode=TwoWay}"
                          Margin="0,14,0,0"/>
            </StackPanel>
        </DataTemplate>

    </Application.Resources>
</Application>
