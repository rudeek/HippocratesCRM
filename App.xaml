<Application x:Class="MyHippocrates.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:MyHippocrates.Models"
             xmlns:vm="clr-namespace:MyHippocrates.ViewModels"
             StartupUri="Views/ConnectionWindow.xaml">
    <Application.Resources>

        <!-- MANUFACTURER -->
        <DataTemplate DataType="{x:Type models:Manufacturer}">
            <StackPanel Width="440">
                <Label Content="Название *"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Страна *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="OnlyLetters_PreviewTextInput"/>
                <Label Content="Адрес *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Телефон * (начинается с +)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="PhoneNumber_PreviewTextInput"/>
                <Label Content="Email * (содержит @)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>

        <!-- PHARMACY -->
        <DataTemplate DataType="{x:Type models:Pharmacy}">
            <StackPanel Width="440">
                <Label Content="Адрес *"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Телефон * (начинается с +)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="PhoneNumber_PreviewTextInput"/>
                <Label Content="Часы работы *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding WorkingHours, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>

        <!-- EMPLOYEE -->
        <DataTemplate DataType="{x:Type models:Employee}">
            <StackPanel Width="440">
                <Label Content="ФИО *"/>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="OnlyLetters_PreviewTextInput"/>
                <Label Content="IDNP * (13 цифр)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Idnp, UpdateSourceTrigger=PropertyChanged}" MaxLength="13"/>
                <Label Content="Телефон * (начинается с +)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="PhoneNumber_PreviewTextInput"/>
                <Label Content="Адрес" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Зарплата * (> 0)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Salary, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Должность *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="OnlyLetters_PreviewTextInput"/>
            </StackPanel>
        </DataTemplate>

        <!-- PRODUCT -->
        <DataTemplate DataType="{x:Type vm:ProductEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Название *"/>
                <TextBox Text="{Binding Entity.Name, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Производитель *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Manufacturers}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding Entity.ManufacturerId, Mode=TwoWay}"/>
                <Label Content="Дата производства *" Margin="0,12,0,0"/>
                <DatePicker SelectedDate="{Binding Entity.ProductionDate, Mode=TwoWay}"/>
                <Label Content="Срок годности * (позже даты производства)" Margin="0,12,0,0"/>
                <DatePicker SelectedDate="{Binding Entity.ExpirationDate, Mode=TwoWay}"/>
                <Label Content="Единица измерения *" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Unit, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Описание" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                <Label Content="Закупочная цена * (> 0)" Margin="0,12,0,0"/>
                <TextBox PreviewTextInput="Price_PreviewTextInput">
                    <TextBox.Text>
                        <Binding Path="Entity.PurchasePrice"
                                 UpdateSourceTrigger="LostFocus"
                                 StringFormat="{}{0:0.##}"/>
                    </TextBox.Text>
                </TextBox>
                <Label Content="Розничная цена * (≥ закупочной)" Margin="0,12,0,0"/>
                <TextBox PreviewTextInput="Price_PreviewTextInput">
                    <TextBox.Text>
                        <Binding Path="Entity.SalePrice"
                                 UpdateSourceTrigger="LostFocus"
                                 StringFormat="{}{0:0.##}"/>
                    </TextBox.Text>
                </TextBox>
                <CheckBox Content="Требует рецепта"
                          IsChecked="{Binding Entity.PrescriptionRequired, Mode=TwoWay}"
                          Margin="0,14,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- RECEIPT -->
        <DataTemplate DataType="{x:Type vm:ReceiptEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Номер чека *"/>
                <TextBox Text="{Binding Entity.ReceiptNumber, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Аптека *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Pharmacies}"
                          DisplayMemberPath="Address"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding Entity.PharmacyId, Mode=TwoWay}"/>
                <Label Content="Сотрудник *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Employees}"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding Entity.EmployeeId, Mode=TwoWay}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ORDER ITEM -->
        <DataTemplate DataType="{x:Type vm:OrderItemEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Чек *"/>
                <ComboBox ItemsSource="{Binding Receipts}"
                          DisplayMemberPath="ReceiptNumber"
                          SelectedValuePath="Id"
                          SelectedItem="{Binding SelectedReceipt, Mode=TwoWay}"/>
                <Label Content="Товар * (только из склада выбранной аптеки)" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding AvailableProducts}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"/>
                <Label Content="Количество * (> 0)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Quantity, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="OnlyDigits_PreviewTextInput"/>
                <Label Content="Скидка % (0–100)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.Discount, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="Price_PreviewTextInput"/>
            </StackPanel>
        </DataTemplate>

        <!-- STOCK BALANCE -->
        <DataTemplate DataType="{x:Type vm:StockBalanceEditorViewModel}">
            <StackPanel Width="440">
                <Label Content="Аптека *"/>
                <ComboBox ItemsSource="{Binding Pharmacies}"
                          DisplayMemberPath="Address"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding Entity.PharmacyId, Mode=TwoWay}"/>
                <Label Content="Товар *" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Products}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding Entity.ProductId, Mode=TwoWay}"/>
                <Label Content="Остаток (≥ 0)" Margin="0,12,0,0"/>
                <TextBox Text="{Binding Entity.RemainingQty, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>

    </Application.Resources>
</Application>
