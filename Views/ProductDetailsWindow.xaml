<Window x:Class="MyHippocrates.Views.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyHippocrates.Views"
        Title="Карточка товара"
        Width="720"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4FBFA"
        Icon="/icon.ico">

    <Window.Resources>
        <local:ProductImageConverter x:Key="ProductImageConverter"/>
        <local:MissingImageVisibilityConverter x:Key="MissingImageVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#E9F6F2"
                BorderBrush="#D0EAE3"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True">
            <Grid>
                <Image Source="{Binding Product.FilePath, Converter={StaticResource ProductImageConverter}}"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Нет фото"
                           Foreground="#6A9489"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding Product.FilePath, Converter={StaticResource MissingImageVisibilityConverter}}"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="26 0 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding Product.Name}"
                           Foreground="#123C33"
                           FontSize="26"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Product.SalePrice, StringFormat={}{0:F2} MDL}"
                           Foreground="#035b4b"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0 12 0 18"/>

                <UniformGrid Columns="2" Margin="0 0 0 18">
                    <StackPanel Margin="0 0 14 10">
                        <TextBlock Text="Категория" Foreground="#6B9086" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Product.Category.Name}" Foreground="#123C33" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0 0 0 10">
                        <TextBlock Text="Производитель" Foreground="#6B9086" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Product.Manufacturer.Name}" Foreground="#123C33" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0 0 14 10">
                        <TextBlock Text="Единица" Foreground="#6B9086" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Product.Unit}" Foreground="#123C33" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0 0 0 10">
                        <TextBlock Text="В наличии" Foreground="#6B9086" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RemainingText}" Foreground="#123C33" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0 0 14 10">
                        <TextBlock Text="Срок годности" Foreground="#6B9086" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Product.ExpirationDate, StringFormat={}{0:dd.MM.yyyy}}" Foreground="#123C33" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0 0 0 10">
                        <TextBlock Text="Рецепт" Foreground="#6B9086" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PrescriptionText}" Foreground="#123C33" FontSize="14"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="Описание" Foreground="#6B9086" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding DescriptionText}"
                           Foreground="#123C33"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Margin="0 5 0 0"/>
            </StackPanel>

            <Button Grid.Row="1"
                    Content="Закрыть"
                    Width="120"
                    Height="38"
                    HorizontalAlignment="Right"
                    Background="#035b4b"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
