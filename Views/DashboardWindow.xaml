<Window x:Class="MyHippocrates.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyHippocrates.Controls"
        Title="Hippocrates — Аналитика"
        Width="1380" Height="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F0"
        Icon="/icon.ico">

	<Window.Resources>

		<!-- ── Цвета ──────────────────────────────────────────── -->
		<SolidColorBrush x:Key="BgPage"       Color="#F0F4F0"/>
		<SolidColorBrush x:Key="BgCard"       Color="#FFFFFF"/>
		<SolidColorBrush x:Key="BgHeader"     Color="#1B5E20"/>
		<SolidColorBrush x:Key="BgFilterBar"  Color="#FFFFFF"/>
		<SolidColorBrush x:Key="AccentGreen"  Color="#2E7D32"/>
		<SolidColorBrush x:Key="AccentLight"  Color="#43A047"/>
		<SolidColorBrush x:Key="TextDark"     Color="#1C2B1C"/>
		<SolidColorBrush x:Key="TextMid"      Color="#4A6349"/>
		<SolidColorBrush x:Key="TextLight"    Color="#7A9A79"/>
		<SolidColorBrush x:Key="BorderLight"  Color="#D6E8D6"/>

		<!-- ── Тени через эффекты ────────────────────────────── -->
		<DropShadowEffect x:Key="CardShadow"
                          Color="#000000" Opacity="0.08"
                          BlurRadius="16" ShadowDepth="2" Direction="270"/>

		<DropShadowEffect x:Key="KpiShadow"
                          Color="#2E7D32" Opacity="0.12"
                          BlurRadius="20" ShadowDepth="0"/>

		<!-- ── Стиль карточки ────────────────────────────────── -->
		<Style x:Key="Card" TargetType="Border">
			<Setter Property="Background"    Value="{StaticResource BgCard}"/>
			<Setter Property="CornerRadius"  Value="12"/>
			<Setter Property="Effect"        Value="{StaticResource CardShadow}"/>
			<Setter Property="Padding"       Value="18"/>
			<Setter Property="Margin"        Value="6"/>
		</Style>

		<!-- ── Заголовок секции ──────────────────────────────── -->
		<Style x:Key="SectionTitle" TargetType="TextBlock">
			<Setter Property="FontSize"     Value="14"/>
			<Setter Property="FontWeight"   Value="SemiBold"/>
			<Setter Property="Foreground"   Value="{StaticResource TextDark}"/>
			<Setter Property="Margin"       Value="0 0 0 12"/>
		</Style>

		<!-- ── Кнопка применить ─────────────────────────────── -->
		<Style x:Key="BtnApply" TargetType="Button">
			<Setter Property="Background"      Value="#2E7D32"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding"         Value="16 8"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#43A047"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── Кнопка сброс ─────────────────────────────────── -->
		<Style x:Key="BtnReset" TargetType="Button" BasedOn="{StaticResource BtnApply}">
			<Setter Property="Background" Value="#78909C"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#546E7A"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<!-- ── Кнопка экспорт ───────────────────────────────── -->
		<Style x:Key="BtnExport" TargetType="Button" BasedOn="{StaticResource BtnApply}">
			<Setter Property="Background" Value="#1565C0"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#1976D2"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<!-- ── ComboBox фильтров ─────────────────────────────── -->
		<Style x:Key="FilterCombo" TargetType="ComboBox">
			<Setter Property="Background"    Value="#F5F9F5"/>
			<Setter Property="BorderBrush"   Value="#C8DEC8"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding"       Value="8 6"/>
			<Setter Property="FontSize"      Value="12"/>
			<Setter Property="MinWidth"      Value="160"/>
		</Style>

		<!-- ── DatePicker фильтров ───────────────────────────── -->
		<Style x:Key="FilterDate" TargetType="DatePicker">
			<Setter Property="Background"  Value="#F5F9F5"/>
			<Setter Property="FontSize"    Value="12"/>
			<Setter Property="MinWidth"    Value="115"/>
		</Style>

		<!-- ── DataGrid ──────────────────────────────────────── -->
		<Style TargetType="DataGrid">
			<Setter Property="Background"               Value="White"/>
			<Setter Property="RowBackground"            Value="White"/>
			<Setter Property="AlternatingRowBackground" Value="#F7FBF7"/>
			<Setter Property="Foreground"               Value="#2C3E2C"/>
			<Setter Property="BorderBrush"              Value="#D6E8D6"/>
			<Setter Property="BorderThickness"          Value="1"/>
			<Setter Property="FontSize"                 Value="12"/>
			<Setter Property="GridLinesVisibility"      Value="Horizontal"/>
			<Setter Property="HorizontalGridLinesBrush" Value="#E8F5E9"/>
			<Setter Property="SelectionMode"            Value="Single"/>
			<Setter Property="SelectionUnit"            Value="FullRow"/>
			<Setter Property="AutoGenerateColumns"      Value="False"/>
			<Setter Property="CanUserAddRows"           Value="False"/>
			<Setter Property="CanUserDeleteRows"        Value="False"/>
			<Setter Property="IsReadOnly"               Value="True"/>
			<Setter Property="HeadersVisibility"        Value="Column"/>
		</Style>
		<Style TargetType="DataGridColumnHeader">
			<Setter Property="Background"      Value="#E8F5E9"/>
			<Setter Property="Foreground"      Value="#1B5E20"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="FontSize"        Value="11"/>
			<Setter Property="Padding"         Value="10 7"/>
			<Setter Property="BorderBrush"     Value="#C8DEC8"/>
			<Setter Property="BorderThickness" Value="0 0 1 1"/>
		</Style>
		<Style TargetType="DataGridRow">
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#C8E6C9"/>
				</Trigger>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#F1F8E9"/>
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style TargetType="DataGridCell">
			<Setter Property="Padding"         Value="8 4"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="Transparent"/>
					<Setter Property="Foreground" Value="#1B5E20"/>
				</Trigger>
			</Style.Triggers>
		</Style>

	</Window.Resources>

	<DockPanel>

		<!-- ══ ШАПКА ════════════════════════════════════════════ -->
		<Border DockPanel.Dock="Top" Background="{StaticResource BgHeader}"
                Padding="24 14">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<!-- Лого + заголовок -->
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<Border Background="#2E7D32" CornerRadius="8"
                            Padding="10 6" Margin="0 0 14 0">
						<TextBlock Text="📊" FontSize="22"/>
					</Border>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="HIPPOCRATES"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White"/>
						<TextBlock Text="Панель аналитики"
                                   FontSize="11" Foreground="#A5D6A7"/>
					</StackPanel>
				</StackPanel>

				<!-- Статус -->
				<StackPanel Grid.Column="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
					<TextBlock Text="{Binding StatusText}"
                               FontSize="12" Foreground="#A5D6A7"
                               HorizontalAlignment="Center"/>
					<TextBlock Text="{Binding LastUpdated}"
                               FontSize="10" Foreground="#66BB6A"
                               HorizontalAlignment="Center"/>
				</StackPanel>

				<!-- Кнопка экспорт -->
            </Grid>
		</Border>

		<!-- ══ ПАНЕЛЬ ФИЛЬТРОВ ══════════════════════════════════ -->
		<Border DockPanel.Dock="Top"
                Background="{StaticResource BgFilterBar}"
                BorderBrush="{StaticResource BorderLight}"
                BorderThickness="0 0 0 1"
                Padding="18 10">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">

				<!-- Иконка -->
				<TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center"
                           Margin="0 0 10 0"/>

				<!-- Период -->
				<TextBlock Text="Период:" FontSize="11" Foreground="{StaticResource TextMid}"
                           VerticalAlignment="Center" Margin="0 0 6 0"/>
				<DatePicker SelectedDate="{Binding DateFrom}"
                            Style="{StaticResource FilterDate}"/>
				<TextBlock Text="—" VerticalAlignment="Center"
                           Margin="6 0" Foreground="{StaticResource TextLight}"/>
				<DatePicker SelectedDate="{Binding DateTo}"
                            Style="{StaticResource FilterDate}"/>

				<Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="14 0"/>

				<!-- Аптека -->
				<TextBlock Text="Аптека:" FontSize="11" Foreground="{StaticResource TextMid}"
                           VerticalAlignment="Center" Margin="0 0 6 0"/>
				<ComboBox ItemsSource="{Binding PharmacyOptions}"
                          SelectedItem="{Binding SelectedPharmacy}"
                          Style="{StaticResource FilterCombo}"/>

				<Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="14 0"/>

				<!-- Категория -->
				<TextBlock Text="Категория:" FontSize="11" Foreground="{StaticResource TextMid}"
                           VerticalAlignment="Center" Margin="0 0 6 0"/>
				<ComboBox ItemsSource="{Binding CategoryOptions}"
                          SelectedItem="{Binding SelectedCategory}"
                          Style="{StaticResource FilterCombo}" MinWidth="130"/>

				<Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="14 0"/>

				<!-- Топ N -->
				<TextBlock Text="Топ:" FontSize="11" Foreground="{StaticResource TextMid}"
                           VerticalAlignment="Center" Margin="0 0 6 0"/>
				<ComboBox ItemsSource="{Binding TopNOptions}"
                          SelectedItem="{Binding TopN}"
                          Style="{StaticResource FilterCombo}" MinWidth="70"/>

				<Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="14 0"/>

				<!-- Кнопки -->
				<Button Content="✔  Применить"
                        Style="{StaticResource BtnApply}"
                        Command="{Binding ApplyFiltersCommand}"
                        Margin="0 0 8 0"/>
				<Button Content="↺  Сброс"
                        Style="{StaticResource BtnReset}"
                        Command="{Binding ResetFiltersCommand}"/>
			</StackPanel>
		</Border>

		<!-- ══ ОСНОВНОЙ КОНТЕНТ ══════════════════════════════════ -->
		<ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BgPage}">
			<StackPanel Margin="12 10 12 20">

				<!-- ── KPI CARDS ─────────────────────────────── -->
				<ItemsControl ItemsSource="{Binding KpiCards}" Margin="0 0 0 4">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid Rows="1" Columns="6"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Margin="6 4" CornerRadius="12"
                                    Background="White"
                                    Effect="{StaticResource KpiShadow}"
                                    Padding="14 12">
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="BorderThickness" Value="0 3 0 0"/>
										<Setter Property="BorderBrush" Value="{Binding Color}"/>
									</Style>
								</Border.Style>
								<StackPanel>
									<StackPanel Orientation="Horizontal" Margin="0 0 0 4">
										<TextBlock Text="{Binding Icon}" FontSize="18"
                                                   Margin="0 0 8 0" VerticalAlignment="Center"/>
										<TextBlock Text="{Binding Title}"
                                                   FontSize="10" Foreground="#78909C"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" MaxWidth="90"/>
									</StackPanel>
									<TextBlock Text="{Binding Value}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#1C2B1C"
                                               TextTrimming="CharacterEllipsis"/>
									<TextBlock Text="{Binding SubValue}"
                                               FontSize="10" Foreground="#90A490"
                                               Margin="0 2 0 0"/>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<!-- ── СТРОКА 1: Линейный + Пирог ───────────── -->
				<Grid Margin="0 4 0 0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="2*"/>
						<ColumnDefinition Width="1*"/>
					</Grid.ColumnDefinitions>

					<!-- Линейный: выручка по месяцам -->
					<Border Style="{StaticResource Card}">
						<DockPanel>
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="0 0 0 8">
								<Border Background="#E8F5E9" CornerRadius="6"
                                        Padding="6 3" Margin="0 0 10 0">
									<TextBlock Text="📈" FontSize="14"/>
								</Border>
								<TextBlock Text="Выручка по месяцам"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" VerticalAlignment="Center"/>
							</StackPanel>
							<local:LineChart Items="{Binding RevenueByMonth}"
                                            Height="210"/>
						</DockPanel>
					</Border>

					<!-- Круговой: по рецепту / без -->
					<Border Style="{StaticResource Card}" Grid.Column="1">
						<DockPanel>
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="0 0 0 8">
								<Border Background="#FCE4EC" CornerRadius="6"
                                        Padding="6 3" Margin="0 0 10 0">
									<TextBlock Text="🥧" FontSize="14"/>
								</Border>
								<TextBlock Text="По рецепту / Без"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" VerticalAlignment="Center"/>
							</StackPanel>
							<local:PieChart Items="{Binding SalesByCategory}"
                                           Height="210"/>
						</DockPanel>
					</Border>
				</Grid>

				<!-- ── СТРОКА 2: Столбчатый аптеки + Столбчатый товары ── -->
				<Grid Margin="0 4 0 0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<!-- Столбчатый: выручка по аптекам -->
					<Border Style="{StaticResource Card}">
						<DockPanel>
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="0 0 0 8">
								<Border Background="#E3F2FD" CornerRadius="6"
                                        Padding="6 3" Margin="0 0 10 0">
									<TextBlock Text="🏪" FontSize="14"/>
								</Border>
								<TextBlock Text="Выручка по аптекам (топ)"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" VerticalAlignment="Center"/>
							</StackPanel>
							<local:BarChart Items="{Binding RevenueByPharmacy}"
                                           Height="200"/>
						</DockPanel>
					</Border>

					<!-- Столбчатый: топ товары -->
					<Border Style="{StaticResource Card}" Grid.Column="1">
						<DockPanel>
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="0 0 0 8">
								<Border Background="#FFF3E0" CornerRadius="6"
                                        Padding="6 3" Margin="0 0 10 0">
									<TextBlock Text="💊" FontSize="14"/>
								</Border>
								<TextBlock Text="Топ товаров по выручке"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" VerticalAlignment="Center"/>
							</StackPanel>
							<local:BarChart Items="{Binding TopProductsChart}"
                                           Height="200"/>
						</DockPanel>
					</Border>
				</Grid>

				<!-- ── СТРОКА 3: Таблица товаров + Low stock ── -->
				<Grid Margin="0 4 0 0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="3*"/>
						<ColumnDefinition Width="2*"/>
					</Grid.ColumnDefinitions>

					<!-- Топ товаров — таблица -->
					<Border Style="{StaticResource Card}">
						<DockPanel>
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="0 0 0 10">
								<Border Background="#F3E5F5" CornerRadius="6"
                                        Padding="6 3" Margin="0 0 10 0">
									<TextBlock Text="📋" FontSize="14"/>
								</Border>
								<TextBlock Text="Детализация продаж по товарам"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" VerticalAlignment="Center"/>
							</StackPanel>
							<DataGrid ItemsSource="{Binding TopProducts}"
                                      MaxHeight="220">
								<DataGrid.Columns>
									<DataGridTextColumn Header="Товар"
                                        Binding="{Binding ProductName}" Width="*"/>
									<DataGridTextColumn Header="Производитель"
                                        Binding="{Binding ManufacturerName}" Width="110"/>
									<DataGridTextColumn Header="Кол-во"
                                        Binding="{Binding TotalQty}" Width="60"/>
									<DataGridTextColumn Header="Выручка"
                                        Binding="{Binding TotalRevenue, StringFormat={}{0:F2}}" Width="90"/>
									<DataGridTextColumn Header="Скидка%"
                                        Binding="{Binding AvgDiscount, StringFormat={}{0:F1}}" Width="70"/>
									<DataGridTextColumn Header="Цена"
                                        Binding="{Binding UnitPrice, StringFormat={}{0:F2}}" Width="75"/>
									<DataGridTextColumn Header="Рецепт"
                                        Binding="{Binding PrescriptionRequired}" Width="65"/>
								</DataGrid.Columns>
							</DataGrid>
						</DockPanel>
					</Border>

					<!-- Низкий остаток -->
					<Border Style="{StaticResource Card}" Grid.Column="1">
						<DockPanel>
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="0 0 0 10">
								<Border Background="#FFEBEE" CornerRadius="6"
                                        Padding="6 3" Margin="0 0 10 0">
									<TextBlock Text="⚠️" FontSize="14"/>
								</Border>
								<TextBlock Text="Низкий остаток (&lt; 20 ед.)"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" VerticalAlignment="Center"/>
							</StackPanel>

							<!-- Пустой placeholder -->
							<TextBlock Text="Все товары в норме ✓"
                                       Foreground="#66BB6A" FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0 20">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding LowStock.Count}" Value="0">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>

							<DataGrid ItemsSource="{Binding LowStock}"
                                      MaxHeight="220">
								<DataGrid.RowStyle>
									<Style TargetType="DataGridRow">
										<Setter Property="Background" Value="White"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding RemainingQty}" Value="0">
												<Setter Property="Background" Value="#FFCDD2"/>
											</DataTrigger>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter Property="Background" Value="#FFF9C4"/>
											</Trigger>
										</Style.Triggers>
									</Style>
								</DataGrid.RowStyle>
								<DataGrid.Columns>
									<DataGridTextColumn Header="Аптека"
                                        Binding="{Binding PharmacyAddress}" Width="*"/>
									<DataGridTextColumn Header="Товар"
                                        Binding="{Binding ProductName}" Width="120"/>
									<DataGridTemplateColumn Header="Остаток" Width="70">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<Border CornerRadius="4" Padding="4 2"
                                                        HorizontalAlignment="Center">
													<Border.Style>
														<Style TargetType="Border">
															<Setter Property="Background" Value="#FFF9C4"/>
															<Style.Triggers>
																<DataTrigger Binding="{Binding Qty}" Value="0">
																	<Setter Property="Background" Value="#FFCDD2"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<TextBlock Text="{Binding Qty}"
                                                               FontWeight="Bold" FontSize="12"
                                                               Foreground="#B71C1C"
                                                               HorizontalAlignment="Center"/>
												</Border>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
								</DataGrid.Columns>
							</DataGrid>
						</DockPanel>
					</Border>
				</Grid>

				<!-- ── СТРОКА 4: Выручка по аптекам — таблица ── -->
				<Border Style="{StaticResource Card}" Margin="6 4 6 4">
					<DockPanel>
						<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="0 0 0 10">
							<Border Background="#E8F5E9" CornerRadius="6"
                                    Padding="6 3" Margin="0 0 10 0">
								<TextBlock Text="🏥" FontSize="14"/>
							</Border>
							<TextBlock Text="Сводка по аптекам"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0" VerticalAlignment="Center"/>
						</StackPanel>
						<DataGrid ItemsSource="{Binding PharmacyRevenue}"
                                  MaxHeight="200">
							<DataGrid.Columns>
								<DataGridTextColumn Header="Аптека"
                                    Binding="{Binding PharmacyAddress}" Width="*"/>
								<DataGridTextColumn Header="Выручка"
                                    Binding="{Binding TotalRevenue, StringFormat={}{0:F2}}" Width="110"/>
								<DataGridTextColumn Header="Чеков"
                                    Binding="{Binding ReceiptCount}" Width="70"/>
								<DataGridTextColumn Header="Средний чек"
                                    Binding="{Binding AvgReceipt, StringFormat={}{0:F2}}" Width="110"/>
								<DataGridTextColumn Header="Мин. чек"
                                    Binding="{Binding MinReceipt, StringFormat={}{0:F2}}" Width="100"/>
								<DataGridTextColumn Header="Макс. чек"
                                    Binding="{Binding MaxReceipt, StringFormat={}{0:F2}}" Width="100"/>
							</DataGrid.Columns>
						</DataGrid>
					</DockPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>

	</DockPanel>
</Window>
