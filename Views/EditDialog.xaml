<Window x:Class="MyHippocrates.Views.EditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование"
        Width="520" Height="671"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF">

    <Window.Resources>

        <!-- Переопределяем глобальные стили из App.xaml для светлой темы -->
        <Style TargetType="Label">
            <Setter Property="Foreground"  Value="#4A7A6A"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="0 0 0 3"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#F4FBFA"/>
            <Setter Property="Foreground"      Value="#0d2e28"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10 8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="CaretBrush"      Value="#035b4b"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#035b4b"/>
                                <Setter Property="Background"  Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="#F4FBFA"/>
            <Setter Property="Foreground"      Value="#0d2e28"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10 8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#F4FBFA"/>
            <Setter Property="Foreground"      Value="#0d2e28"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10 7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7">
                                                        <Path HorizontalAlignment="Right"
                                                              VerticalAlignment="Center"
                                                              Margin="0 0 10 0"
                                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                                              Fill="#035b4b"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10 0 28 0"
                                              VerticalAlignment="Center"/>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="#a8d5cb"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Margin="0 2 0 0">
                                    <ScrollViewer MaxHeight="200">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background"      Value="#F4FBFA"/>
            <Setter Property="Foreground"      Value="#0d2e28"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="6 4"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="#0d2e28"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
        </Style>

        <!-- Кнопка Сохранить -->
        <Style x:Key="BtnSave" TargetType="Button">
            <Setter Property="Background"      Value="#035b4b"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="24 10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#024a3d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка Отмена -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#4A7A6A"/>
            <Setter Property="FontWeight"      Value="Normal"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="24 10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#edf8f5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel Background="#FFFFFF">

        <!-- Шапка диалога -->
        <Border DockPanel.Dock="Top"
                Background="#035b4b"
                Padding="24 16">
            <StackPanel>
                <TextBlock x:Name="TxtTitle"
                           Text="Редактирование записи"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Заполните все обязательные поля"
                           Foreground="#9dd5c8"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Margin="0 3 0 0"/>
            </StackPanel>
        </Border>

        <!-- Кнопки снизу -->
        <Border DockPanel.Dock="Bottom"
                Background="#FFFFFF"
                BorderBrush="#cce3de"
                BorderThickness="0 1 0 0"
                Padding="24 14">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Style="{StaticResource BtnCancel}"
                        Content="Отмена"
                        Click="Cancel_Click"/>
                <Button Style="{StaticResource BtnSave}"
                        Margin="10 0 0 0"
                        Click="Save_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✔" Margin="0 0 6 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Сохранить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Контент (форма) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Background="#FFFFFF"
                      Padding="24 20">
            <ContentControl Content="{Binding}" Margin="0"/>
        </ScrollViewer>

    </DockPanel>
</Window>
