<Window x:Class="MyHippocrates.Views.EditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D1F0F">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="18 8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Заголовок -->
        <Border DockPanel.Dock="Top" Background="#1A3D1C" Padding="16 12">
            <TextBlock Text="✎  Редактирование записи"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <!-- Кнопки снизу -->
        <Border DockPanel.Dock="Bottom" Background="#132B15" Padding="16 10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Background="#546E7A" Foreground="White"
                        Width="100" Click="Cancel_Click"/>
                <Button Content="✔ Сохранить" Background="#2E7D32" Foreground="White"
                        Width="130" Margin="10 0 0 0" Click="Save_Click"/>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0D1F0F">
            <ContentControl Content="{Binding}" Margin="20"/>
        </ScrollViewer>
    </DockPanel>
</Window>