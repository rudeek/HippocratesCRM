<Window x:Class="MyHippocrates.Views.ReceiptPrintSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор чека для печати"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4FBFA"
        Icon="/icon.ico">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0 0 0 16">
            <TextBlock Text="Выберите чек"
                       Foreground="#123C33"
                       FontSize="22"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Печать доступна для чеков за сегодня по выбранной аптеке"
                       Foreground="#6B9086"
                       FontSize="13"
                       Margin="0 4 0 0"/>
        </StackPanel>

        <ListBox Grid.Row="1"
                 x:Name="ReceiptsList"
                 ItemsSource="{Binding Receipts}"
                 SelectedItem="{Binding SelectedReceipt, Mode=TwoWay}"
                 MouseDoubleClick="Print_Click"
                 BorderBrush="#D0EAE3"
                 BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12 10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding ReceiptNumber, StringFormat=Чек №{0}}"
                                           Foreground="#123C33"
                                           FontWeight="SemiBold"
                                           FontSize="15"/>
                                <TextBlock Foreground="#6B9086" FontSize="12">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:dd.MM.yyyy} {1:hh\\:mm}">
                                            <Binding Path="Date"/>
                                            <Binding Path="Time"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TotalAmount, StringFormat={}{0:F2} MDL}"
                                       Foreground="#035b4b"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 18 0 0">
            <Button Content="Отмена"
                    Width="110"
                    Height="38"
                    Margin="0 0 10 0"
                    Click="Cancel_Click"/>
            <Button Content="Печатать"
                    Width="120"
                    Height="38"
                    Background="#035b4b"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="Print_Click"/>
        </StackPanel>
    </Grid>
</Window>
