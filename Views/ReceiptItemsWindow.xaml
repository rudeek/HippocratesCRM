<Window x:Class="MyHippocrates.Views.ReceiptItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиции чека"
        Width="900" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        Icon="/icon.ico">

    <Window.Resources>
        <!-- ══ Цвета (синхронизированы с MainWindow) ══ -->
        <SolidColorBrush x:Key="AccentGreen"    Color="#035b4b"/>
        <SolidColorBrush x:Key="AccentGreenHov" Color="#024a3d"/>
        <SolidColorBrush x:Key="BorderLight"    Color="#cce3de"/>
        <SolidColorBrush x:Key="TextDark"       Color="#012920"/>
        <SolidColorBrush x:Key="TextMid"        Color="#2d6b5a"/>
        <SolidColorBrush x:Key="BgRowAlt"       Color="#f4fbf9"/>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="Background"               Value="#FFFFFF"/>
            <Setter Property="RowBackground"            Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#f4fbf9"/>
            <Setter Property="Foreground"               Value="#012920"/>
            <Setter Property="BorderBrush"              Value="#cce3de"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="GridLinesVisibility"      Value="None"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
            <Setter Property="RowHeight"                Value="44"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#035b4b"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="14 10"/>
            <Setter Property="BorderBrush"     Value="#024a3d"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="BorderBrush"     Value="#e0f0ec"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#d0ede7"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e8f5f1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"           Value="14 0"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#012920"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопка зелёная -->
        <Style x:Key="BtnAdd" TargetType="Button">
            <Setter Property="Background"      Value="#035b4b"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20 9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#024a3d"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9dccc0"/>
                                <Setter Property="Foreground" Value="#5a9b88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка контурная зелёная -->
        <Style x:Key="BtnEdit" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#035b4b"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderBrush"     Value="#035b4b"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding"         Value="20 9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e5f4ef"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="BorderBrush" Value="#9dccc0"/>
                                <Setter Property="Foreground"  Value="#B0C8B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка контурная красная -->
        <Style x:Key="BtnDelete" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#C0392B"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderBrush"     Value="#C0392B"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding"         Value="20 9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FDF2F2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="BorderBrush" Value="#E8C5C2"/>
                                <Setter Property="Foreground"  Value="#E8C5C2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Background="#FFFFFF">

        <!-- Шапка -->
        <Border DockPanel.Dock="Top"
                Background="#035b4b"
                Padding="24 16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TxtReceiptTitle"
                               Text="Позиции чека"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TxtReceiptSubtitle"
                               Foreground="#9dd5c8"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               Margin="0 3 0 0"/>
                </StackPanel>
                <!-- Итого в шапке -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Итого по чеку"
                               Foreground="#9dd5c8"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TxtTotal"
                               Text="0.00 MDL"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопка Закрыть снизу -->
        <Border DockPanel.Dock="Bottom"
                Background="#FFFFFF"
                BorderBrush="#cce3de"
                BorderThickness="0 1 0 0"
                Padding="24 14">
            <Button Style="{StaticResource BtnAdd}"
                    Content="Закрыть"
                    HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </Border>

        <!-- Тулбар + таблица -->
        <Grid Margin="24 16 24 16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Тулбар -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0 0 0 14">
                <Button Style="{StaticResource BtnAdd}"
                        x:Name="BtnAdd"
                        Click="Add_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊕" FontSize="15" Margin="0 0 6 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Добавить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnEdit}"
                        x:Name="BtnEdit"
                        Margin="8 0"
                        IsEnabled="False"
                        Click="Edit_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✎" FontSize="14" Margin="0 0 6 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Изменить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnDelete}"
                        x:Name="BtnDelete"
                        IsEnabled="False"
                        Click="Delete_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑" FontSize="13" Margin="0 0 6 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Удалить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Таблица позиций -->
            <DataGrid Grid.Row="1"
                      x:Name="ItemsGrid"
                      SelectionChanged="ItemsGrid_SelectionChanged"
                      LoadingRow="DataGrid_LoadingRow"
                      UnloadingRow="DataGrid_UnloadingRow">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="№" Width="56">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#5a9b88"
                                           FontSize="12"
                                           Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Товар"
                                        Binding="{Binding Product.Name}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Кол-во"
                                        Binding="{Binding Quantity}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Цена ед."
                                        Binding="{Binding UnitPrice, StringFormat={}{0:F2}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Скидка"
                                        Binding="{Binding Discount, StringFormat={}{0:0.##}%}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Итого"
                                        Binding="{Binding TotalPrice, StringFormat={}{0:F2}}"
                                        Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
