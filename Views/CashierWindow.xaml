<Window x:Class="MyHippocrates.Views.CashierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyHippocrates.Views"
        Title="Hippocrates — Касса"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#EEF8F5"
        Icon="/icon.ico">

    <Window.Resources>
        <local:ProductImageConverter x:Key="ProductImageConverter"/>
        <local:MissingImageVisibilityConverter x:Key="MissingImageVisibilityConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#035b4b"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16 11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#036A4E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B8C9C4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E5F3EF"/>
            <Setter Property="Foreground" Value="#035b4b"/>
        </Style>

        <Style x:Key="CircleActionButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#E5F3EF"/>
            <Setter Property="Foreground" Value="#035b4b"/>
            <Setter Property="BorderBrush" Value="#C7E4DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D4ECE5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteLineButton" TargetType="Button" BasedOn="{StaticResource CircleActionButton}">
            <Setter Property="Background" Value="#FFF1F2"/>
            <Setter Property="Foreground" Value="#BE123C"/>
            <Setter Property="BorderBrush" Value="#FECDD3"/>
        </Style>

        <Style x:Key="ReceiptDiscountBox" TargetType="TextBox">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#035b4b"/>
            <Setter Property="BorderBrush" Value="#B8DDD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="4 0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#123C33"/>
            <Setter Property="BorderBrush" Value="#B8DDD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12 10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#035b4b"
                Padding="28 18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/logoWhite.png"
                           Height="42"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Margin="16 0 0 0">
                        <TextBlock Text="Касса фармацевта"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CashierName}"
                                   Foreground="#A7E2D5"
                                   FontSize="13"
                                   Margin="0 2 0 0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Аптека"
                               Foreground="#A7E2D5"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0 0 10 0"/>
                    <ComboBox ItemsSource="{Binding Pharmacies}"
                              SelectedItem="{Binding SelectedPharmacy, Mode=TwoWay}"
                              DisplayMemberPath="Address"
                              Width="360"
                              Padding="8 6"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Выход"
                        Style="{StaticResource LightButton}"
                        Click="Logout_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0 0 20 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Поиск: добавили x:Name="SearchTextBox" -->
                    <TextBox x:Name="SearchTextBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"/>

                    <!-- Placeholder текст -->
                    <TextBlock Text="Поиск товара"
                           Margin="14 0 0 0"
                           Foreground="#6B9086"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <!-- По умолчанию скрыт -->
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <!-- Условие 1: текст в поле пустой -->
                                            <Condition Binding="{Binding SearchText}" Value=""/>
                                            <!-- Условие 2: поле НЕ в фокусе (ссылка через ElementName) -->
                                            <Condition Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <!-- Если оба условия истинны → показываем подсказку -->
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProductSummary}"
                               Foreground="#416D63"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="18 0 0 0"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ProductCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="214"
                                        Height="360"
                                        Background="White"
                                        BorderBrush="#D0EAE3"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0 0 14 14"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        MouseLeftButtonUp="ProductCard_MouseLeftButtonUp">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="128"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Background="#E9F6F2"
                                                CornerRadius="8 8 0 0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding Product.FilePath, Converter={StaticResource ProductImageConverter}}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="Нет фото"
                                                           Foreground="#6A9489"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding Product.FilePath, Converter={StaticResource MissingImageVisibilityConverter}}"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="1" Margin="14 12 14 8">
                                            <TextBlock Text="{Binding Product.Name}"
                                                       Foreground="#123C33"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="42"/>
                                            <TextBlock Text="{Binding Product.Category.Name}"
                                                       Foreground="#6B9086"
                                                       FontSize="12"
                                                       Margin="0 5 0 0"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Product.SalePrice, StringFormat={}{0:F2} MDL}"
                                                       Foreground="#035b4b"
                                                       FontSize="19"
                                                       FontWeight="Bold"
                                                       Margin="0 10 0 0"/>
                                            <TextBlock Text="{Binding RemainingText}"
                                                       Foreground="#7A8F89"
                                                       FontSize="12"
                                                       Margin="0 4 0 0"/>
                                        </StackPanel>

                                        <Button Grid.Row="2"
                                                Content="Добавить"
                                                Style="{StaticResource PrimaryButton}"
                                                Margin="14 0 14 14"
                                                Tag="{Binding}"
                                                IsEnabled="{Binding DataContext.HasOpenReceipt, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Click="AddProduct_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D0EAE3"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Текущий чек"
                                   Foreground="#123C33"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ReceiptInfo}"
                                   Foreground="#6B9086"
                                   FontSize="13"
                                   Margin="0 4 0 0"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Columns="3"
                                 Margin="0 20 0 16">
                        <Button Content="Открыть"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0 0 6 0"
                                IsEnabled="{Binding CanOpenReceipt}"
                                Click="OpenReceipt_Click"/>
                        <Button Content="Отменить"
                                Style="{StaticResource LightButton}"
                                Margin="6 0"
                                IsEnabled="{Binding HasOpenReceipt}"
                                Click="CancelReceipt_Click"/>
                        <Button Content="Печать"
                                Style="{StaticResource LightButton}"
                                Margin="6 0 0 0"
                                Click="PrintTodayReceipts_Click"/>
                    </UniformGrid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding CurrentLines}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E4F1ED"
                                        BorderThickness="0 0 0 1"
                                        Padding="0 12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductName}"
                                                       Foreground="#123C33"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Details}"
                                                       Foreground="#6B9086"
                                                       FontSize="12"
                                                       Margin="0 3 0 0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="12 0 0 0">
                                            <Button Content="-"
                                                    Style="{StaticResource CircleActionButton}"
                                                    Tag="{Binding}"
                                                    Click="DecreaseLine_Click"/>
                                            <TextBlock Text="{Binding TotalText}"
                                                       Foreground="#035b4b"
                                                       FontWeight="Bold"
                                                       MinWidth="58"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="6 0"/>
                                            <Button Content="+"
                                                    Style="{StaticResource CircleActionButton}"
                                                    Tag="{Binding}"
                                                    Click="IncreaseLine_Click"/>
                                            <Button Content="×"
                                                    Style="{StaticResource DeleteLineButton}"
                                                    Tag="{Binding}"
                                                    Margin="6 0 0 0"
                                                    Click="DeleteLine_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Margin="0 18 0 0">
                        <Grid Margin="0 0 0 10">
                            <TextBlock Text="Сумма товаров"
                                       Foreground="#416D63"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SubtotalText}"
                                       Foreground="#416D63"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0 0 0 10">
                            <TextBlock Text="Скидка"
                                       Foreground="#416D63"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <TextBox Text="{Binding ReceiptDiscountText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ReceiptDiscountBox}"
                                         MaxLength="2"
                                         ToolTip="Скидка на весь чек, максимум 30%"
                                         PreviewTextInput="ReceiptDiscount_PreviewTextInput"
                                         LostFocus="ReceiptDiscount_LostFocus"
                                         KeyDown="ReceiptDiscount_KeyDown"/>
                                <TextBlock Text="%"
                                           Foreground="#416D63"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="6 0 0 0"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0 0 0 16">
                            <TextBlock Text="К оплате"
                                       Foreground="#416D63"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalText}"
                                       Foreground="#035b4b"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Button Content="Закрыть чек"
                                Style="{StaticResource PrimaryButton}"
                                IsEnabled="{Binding CanCloseReceipt}"
                                Click="CloseReceipt_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
