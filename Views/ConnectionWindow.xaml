<Window x:Class="MyHippocrates.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hippocrates — Подключение"
        Width="420" Height="724"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        Icon="/connection.ico">

    <Window.Resources>

        <Style TargetType="Label">
            <Setter Property="Foreground"  Value="#4A7A6A"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="0 0 0 3"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#F4FBFA"/>
            <Setter Property="Foreground"      Value="#0d2e28"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10 9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="CaretBrush"      Value="#035b4b"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#035b4b"/>
                                <Setter Property="Background"  Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="#F4FBFA"/>
            <Setter Property="Foreground"      Value="#0d2e28"/>
            <Setter Property="BorderBrush"     Value="#a8d5cb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10 9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#035b4b"/>
                                <Setter Property="Background"  Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"      Value="#035b4b"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="0 13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#024a3d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Зелёная шапка с логотипом -->
            <RowDefinition Height="Auto"/>
            <!-- Форма -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Шапка ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#035b4b"
                Padding="36 32 36 28">
            <StackPanel HorizontalAlignment="Center">
                <Image Source="/logo.jpg"
                       Height="70"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Подключение к базе данных"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Foreground="#9dd5c8"
                           HorizontalAlignment="Center"
                           Margin="0 10 0 0"/>
            </StackPanel>
        </Border>

        <!-- ══ Форма ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="#FFFFFF">
            <StackPanel Margin="36 28 36 28">

                <Label Content="Сервер"/>
                <TextBox x:Name="TxtHost" Text="localhost"/>

                <Label Content="Порт" Margin="0 14 0 0"/>
                <TextBox x:Name="TxtPort" Text="5432"/>

                <Label Content="База данных" Margin="0 14 0 0"/>
                <TextBox x:Name="TxtDatabase" Text="Hippocrates"/>

                <Label Content="Пользователь" Margin="0 14 0 0"/>
                <TextBox x:Name="TxtUser" Text="postgres"/>

                <Label Content="Пароль" Margin="0 14 0 0"/>
                <PasswordBox x:Name="PwdBox"/>

                <!-- Ошибка -->
                <Border x:Name="ErrorPanel"
                        Background="#FEF2F2"
                        BorderBrush="#FCA5A5"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12 10"
                        Margin="0 14 0 0"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" Foreground="#DC2626"
                                   FontSize="13" Margin="0 0 8 0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtError"
                                   Foreground="#DC2626"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button Content="Подключиться"
                        Margin="0 22 0 0"
                        Click="ConnectButton_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
