<Window x:Class="MyHippocrates.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hippocrates — Подключение"
        Width="420" Height="547"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1F0F"
        Icon="/connection.ico">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#132B15"/>
            <Setter Property="Foreground"      Value="#E8F5E9"/>
            <Setter Property="BorderBrush"     Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="Padding"         Value="8 6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#E8F5E9"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="#132B15"/>
            <Setter Property="Foreground"      Value="#E8F5E9"/>
            <Setter Property="BorderBrush"     Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="Padding"         Value="8 6"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#81C784"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="0 0 0 2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#2E7D32"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="0 12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#43A047"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="36">
        <!-- Лого -->
        <TextBlock Text="HIPPOCRATES" FontSize="30" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center" Margin="0 6 0 2"/>
        <TextBlock Text="Система управления аптекой" FontSize="12"
                   Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 24"/>

        <Label Content="Сервер"/>
        <TextBox x:Name="TxtHost" Text="localhost"/>

        <Label Content="Порт" Margin="0,12,0,0"/>
        <TextBox x:Name="TxtPort" Text="5432"/>

        <Label Content="База данных" Margin="0,12,0,0"/>
        <TextBox x:Name="TxtDatabase" Text="Hippocrates"/>

        <Label Content="Пользователь" Margin="0,12,0,0"/>
        <TextBox x:Name="TxtUser" Text="postgres"/>

        <Label Content="Пароль" Margin="0,12,0,0"/>
        <PasswordBox x:Name="PwdBox"/>

        <TextBlock x:Name="TxtError" Foreground="#EF5350" FontSize="12"
                   TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>

        <Button Content="Подключиться" Margin="0,20,0,0" Click="ConnectButton_Click"/>
    </StackPanel>
</Window>