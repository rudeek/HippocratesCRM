<Window x:Class="MyHippocrates.Views.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="330"
        Height="86"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Opacity="0">
    <Border Background="#035b4b"
            CornerRadius="12"
            Padding="16"
            BorderBrush="#A7E2D5"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#223832"
                              BlurRadius="18"
                              ShadowDepth="3"
                              Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="34"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Width="26"
                    Height="26"
                    CornerRadius="13"
                    Background="#E5F3EF"
                    VerticalAlignment="Center">
                <TextBlock Text="✓"
                           Foreground="#035b4b"
                           FontWeight="Bold"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Message}"
                           Foreground="#D6F4EE"
                           FontSize="12"
                           Margin="0 3 0 0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
